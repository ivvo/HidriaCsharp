<UserControl x:Class="BaslerCam.Controls.BaslerCameraImageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BaslerCam"
             mc:Ignorable="d"
             >
    <Grid>
        <Border x:Name="ImageBoxBorder" ClipToBounds="True" Background="Gray" RenderTransformOrigin="0.5,0.5">
            <Image x:Name="ImageBox" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
        </Border>
    </Grid>
</UserControl>
