<views:MvxWpfView
    xmlns:views="clr-namespace:MvvmCross.Platforms.Wpf.Views;assembly=MvvmCross.Platforms.Wpf"
    xmlns:mvx="clr-namespace:MvvmCross.Platforms.Wpf.Binding;assembly=MvvmCross.Platforms.Wpf"
    x:Class="TemplateGenerator.Wpf.Views.ShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TemplateGenerator.Wpf.Views"
             mc:Ignorable="d" FontSize="20" 
             d:DesignHeight="550" d:DesignWidth="1180"  Background="AliceBlue" Margin="0,0,0,0" Width="1180">
    <Grid HorizontalAlignment="Center" >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="15"/>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="15"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto" MinHeight="44"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="7*"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="10*"/>
            <RowDefinition Height="45"/>
            <RowDefinition Height="45"/>
        </Grid.RowDefinitions>

        <Rectangle Grid.Column="1" HorizontalAlignment="Center" Height="160" Margin="0,15,0,0" Grid.RowSpan="5" Grid.Row="0" Stroke="Gray" Width="296"  Grid.ColumnSpan="2">
            <Rectangle.Effect>
                <BlurEffect Radius="2" KernelType="Gaussian"/>
            </Rectangle.Effect>
        </Rectangle>
        <Rectangle Grid.Column="3" HorizontalAlignment="Center" Height="160" Margin="0,15,0,0" Grid.RowSpan="5" Grid.Row="0" Stroke="Gray" Width="296" Grid.ColumnSpan="2">
            <Rectangle.Effect>
                <BlurEffect Radius="2" KernelType="Gaussian"/>
            </Rectangle.Effect>
        </Rectangle>
        <Rectangle Grid.Column="5" HorizontalAlignment="Center" Height="160" Margin="0,15,0,0" Grid.RowSpan="5" Grid.Row="0" Stroke="Gray" Width="296" >
            <Rectangle.Effect>
                <BlurEffect Radius="2" KernelType="Gaussian"/>
            </Rectangle.Effect>
        </Rectangle>

        <!--Row 1-->
        <TextBox Text="{Binding ProgramName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="2" Grid.Column="1" Margin="10,5,10,5" MinWidth="100" Grid.ColumnSpan="2">
            <TextBox.InputBindings>
                <KeyBinding Key="Enter" Command="{Binding AddProgramCommand}"/>
            </TextBox.InputBindings>
        </TextBox>

        <TextBlock Grid.Row="1" Grid.Column="1" Height="30"  HorizontalAlignment="Left" Grid.ColumnSpan="2"
                       VerticalAlignment="Center" Width="146"><Run Text="  1° Robot name"/></TextBlock>

        <TextBlock Grid.Row="1" Grid.Column="3" Height="30" HorizontalAlignment="Left" Grid.ColumnSpan="2"
                       VerticalAlignment="Center" Width="170"><Run Text="  2° Station name"/></TextBlock>

        <Button mvx:Bi.nd="Command AddProgramCommand" Grid.Row="3"  Grid.Column="1" MinWidth="120" Margin="10,5,5,5"
                Content="Add Robot" FontSize="17"/>

        <Button mvx:Bi.nd="Command RemoveProgramCommand"  Grid.Row="3" Grid.Column="2" MinWidth="70" Margin="5,5,10,5"  
                IsEnabled="{Binding CanClickRemoveProgram}" Content="Remove Robot" FontSize="17"/>

        <!--Označenega shranimo v SelectedRobot, prikažemo pa RobotName-->
        <ComboBox Grid.Row="4" Grid.Column="1" Margin="10,5,10,10" x:Name="Robot"  Grid.ColumnSpan="2"
                  SelectedItem="{Binding SelectedProgram, Mode=TwoWay}"  ItemsSource="{Binding Program}"    
                  DisplayMemberPath="ProgramName">
        </ComboBox>

        <!--Row 2-->
        <TextBox Text="{Binding StationName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="15" Grid.Row="2" Grid.Column="3" Margin="10,5,10,5" MinWidth="100" Grid.ColumnSpan="2">
            <TextBox.InputBindings>
                <KeyBinding Key="Enter" Command="{Binding AddStationCommand}"/>
            </TextBox.InputBindings>
        </TextBox>

        <CheckBox  IsChecked="{Binding StationFreeEnabled}" Grid.Row="4" Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center" Content="Add station free signal"  Grid.ColumnSpan="2" >
            <CheckBox.Style>
                <Style TargetType="CheckBox">
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="HorizontalAlignment" Value="Center"/>
                </Style>
            </CheckBox.Style>
        </CheckBox>

        <Button mvx:Bi.nd="Command AddStationCommand" Grid.Row="3" Grid.Column="3"  Margin="10,5,5,5" Content="Add Station" FontSize="17"/>

        <Button mvx:Bi.nd="Command RemoveStationCommand" Grid.Row="3" Grid.Column="4"  Margin="5,5,10,5" Content="Remove Station" FontSize="17"/>

        <!--Row 3-->
        <TextBlock Grid.Row="1" Grid.Column="5" Height="30" HorizontalAlignment="Left" 
                       VerticalAlignment="Center" Width="184"><Run Text="  3° Select template"/></TextBlock>

        <ComboBox ItemsSource="{Binding Templates}" Grid.Row="2" Grid.Column="5" Margin="10,5,10,5" Height="30" 
                  VerticalAlignment="Center" SelectedItem="{Binding SelectedTemplate}">
        </ComboBox>

        <CheckBox x:Name="SimulationProgram"  Grid.Row="3" Grid.Column="5" HorizontalAlignment="Center" VerticalAlignment="Center" Content="Make program for simulation"  IsChecked="{Binding SimulationProgram}" >
            <CheckBox.Style>
                <Style TargetType="CheckBox">
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="HorizontalAlignment" Value="Center"/>
                </Style>
            </CheckBox.Style>
        </CheckBox>

        <Button Click="GenerateClick" Grid.Row="4" Grid.Column="5" Margin="10,5,10,5" Content="Generate"/>
        
        <Button mvx:Bi.nd="Command TestButtonCommand" Grid.Row="12" Grid.Column="1" Content="test button" FontSize="15" Margin="10,5,10,10"/>

        <!--Row 4-->
        <DataGrid ItemsSource="{Binding Path=SelectedProgram.Stations, UpdateSourceTrigger=PropertyChanged}" Grid.Row="6" Grid.Column="1" MinWidth="300" Margin="0,0,0,0" Grid.RowSpan="5" Grid.ColumnSpan="6"  
                AutoGenerateColumns="False" AlternatingRowBackground="WhiteSmoke" CanUserSortColumns="False" CanUserReorderColumns="False" HeadersVisibility="Column" VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Hidden">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Station name" Binding="{Binding Path=RobotStationName, UpdateSourceTrigger=PropertyChanged}" Width="150"  />
                <DataGridTextColumn Header="Signal name" Binding="{Binding Path=RobotStationNameToUpper, UpdateSourceTrigger=PropertyChanged}" Width="150" />
                <DataGridCheckBoxColumn Header="Free" Binding="{Binding Path=StationFreeEnabled,  UpdateSourceTrigger=PropertyChanged}"   Width="60" CanUserResize="False" MinWidth="60" >
                    <DataGridCheckBoxColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGridCheckBoxColumn.HeaderStyle>
                    <DataGridCheckBoxColumn.ElementStyle>
                        <Style TargetType="CheckBox">
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridCheckBoxColumn.ElementStyle>
                </DataGridCheckBoxColumn>
                <DataGridCheckBoxColumn Header="Pallet" Binding="{Binding Path=Pallet, UpdateSourceTrigger=PropertyChanged}"  Width="70" >
                    <DataGridCheckBoxColumn.ElementStyle>
                        <Style TargetType="CheckBox">
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridCheckBoxColumn.ElementStyle>
                    <DataGridCheckBoxColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGridCheckBoxColumn.HeaderStyle>
                </DataGridCheckBoxColumn>
                <DataGridTextColumn Header="Positions " Binding="{Binding Path=Positions, UpdateSourceTrigger=PropertyChanged}"  Width="100" FontSize="18">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="X cord" Binding="{Binding Path=Xcord, UpdateSourceTrigger=PropertyChanged, StringFormat=F3}"  Width="100" FontSize="18" FontStyle="Italic">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Y cord" Binding="{Binding Path=Ycord, UpdateSourceTrigger=PropertyChanged, StringFormat=F3}"  Width="100" FontSize="18" FontStyle="Italic">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Z cord" Binding="{Binding Path=Zcord, UpdateSourceTrigger=PropertyChanged, StringFormat=F3}"  Width="100" FontSize="18" FontStyle="Italic">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Comment" Binding="{Binding Path=RobotStationComment, UpdateSourceTrigger=PropertyChanged}" Width="301.5" FontStyle="Italic" FontSize="18" >
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="MaxLength" Value="16"/>
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="R1 cord"   Width="90" FontSize="18" FontStyle="Italic" Visibility="Hidden">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.HeaderStyle>

                </DataGridTextColumn>
                <DataGridTextColumn Header="R2 cord"   Width="90" FontSize="18" FontStyle="Italic" Visibility="Hidden">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.HeaderStyle>

                </DataGridTextColumn>
                <DataGridTextColumn Header="R3 cord"   Width="90" FontSize="18" FontStyle="Italic" Visibility="Hidden">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.HeaderStyle>

                </DataGridTextColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- Last Row 10-->
        <TextBlock Grid.Row="11" Grid.Column="2" MinWidth="100" Margin="5,7,95,8" Grid.ColumnSpan="6" Text="{Binding TextUpdate, Mode=OneWay}"/>
        <Image Grid.Column="6" HorizontalAlignment="Left" VerticalAlignment="Top" Height="118" Grid.RowSpan="5" Grid.Row="2"  Width="161" Source="/Views/SCARA_T3_PB2_b4282a04-removebg-preview.png" Margin="77,33,0,0" RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform/>
                    <TranslateTransform/>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>
        <Image Grid.Column="6" HorizontalAlignment="Left" VerticalAlignment="Top" Height="136" Grid.RowSpan="4"  Width="183" Source="/Views/Yamaha_YK1200X_Picture_2.png" Margin="99,4,0,0" Grid.ColumnSpan="2" Grid.Row="1"/>
        <Image Grid.Column="5" HorizontalAlignment="Left" VerticalAlignment="Top" Height="170" Grid.RowSpan="6"  Width="240" Source="/Views/202-2025470_robot-industrial-kawasaki-hd-png-download-removebg-preview.png" Margin="273,10,0,0" Grid.ColumnSpan="2"/>
        <Button mvx:Bi.nd="Command ManualButtonCommand" Grid.Row="11" Grid.Column="6" Content="MANUALS" FontSize="15" Margin="170,7,0,8" Grid.ColumnSpan="1"/>

        <!-- Uvoz obstoječega projekta + posodobitev (dodane postaje). Epson/KUKA/ABB; Yamaha/Kawasaki še ni podprt. -->
        <Button Click="ImportProjectClick" Grid.Row="12" Grid.Column="3" Content="Import Project" FontSize="15" Margin="10,5,5,8"/>
        <Button Click="UpdateProjectClick" Grid.Row="12" Grid.Column="4" Content="Update Project" FontSize="15" Margin="5,5,10,8"/>

    </Grid>
</views:MvxWpfView>

    